%%% Root rebar.config for hecate-app-ragd (RAG plugin daemon)
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% Event sourcing stack (match daemon versions)
    {reckon_db, "1.6.3"},
    {evoq, "1.13.1"},
    {reckon_evoq, "1.5.1"},
    {reckon_gater, "1.3.1"},

    %% HTTP server
    {cowboy, "2.12.0"},

    %% SQLite (read models)
    {esqlite, "0.8.8"},

    %% Hecate plugin SDK
    {hecate_sdk, "~> 0.6"},

    %% Local RAG primitives (this scaffold uses git deps until they
    %% land on hex; flip to versioned hex tags after first release).
    {hecate_vector, {git, "https://codeberg.org/hecate-social/hecate-vector.git", {branch, "main"}}},
    {hecate_embed,  {git, "https://codeberg.org/hecate-social/hecate-embed.git",  {branch, "main"}}}
]}.

{relx, [
    {release, {hecate_app_ragd, "0.1.0"}, [
        hecate_app_ragd,

        reckon_db,
        evoq,
        reckon_evoq,

        rag,

        embed_corpus,
        refresh_corpus,
        serve_retrieval,

        project_chunks,
        project_sources,

        query_chunks,
        query_sources,

        hecate_vector,
        hecate_embed
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_app_ragd]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
